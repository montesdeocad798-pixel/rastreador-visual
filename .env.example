# ── Google Gemini Vision API ──────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
# Plan gratuito: 15 req/min con gemini-1.5-flash
GEMINI_API_KEY=

# ── Serper.dev Shopping Search API ───────────────────────────
# Obtener en: https://serper.dev (2500 búsquedas gratis)
SERPER_API_KEY=

# ── PostgreSQL (aprendizaje por feedback) ─────────────────────
# En Railway: añade el plugin "PostgreSQL" → Railway inyecta DATABASE_URL
# automáticamente. Sin DATABASE_URL la app funciona pero no aprende.
DATABASE_URL=

# ── Servidor ──────────────────────────────────────────────────
# Puerto del servidor Express (Railway lo sobreescribe automáticamente)
PORT=3001
